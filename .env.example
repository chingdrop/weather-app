# ntfy topic — use a long random string, not something guessable
# Subscribe to this topic in the ntfy app to receive notifications
NTFY_TOPIC=replace-with-long-random-topic

# ntfy base URL
# In Docker Compose, leave this as http://ntfy (internal service name)
# For local development against public ntfy.sh, use: NTFY_BASE_URL=https://ntfy.sh
NTFY_BASE_URL=http://ntfy

# Location coordinates
LAT=replace-with-latitude
LON=replace-with-longitude

# IANA timezone name — https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=America/New_York

# Server — use 0.0.0.0 inside Docker, 127.0.0.1 for local dev
HOST=0.0.0.0
PORT=5000

# Set to 0 in production
FLASK_DEBUG=0

# Alert thresholds — all optional, defaults shown
RAIN_PROB_ALERT_PERCENT=50
RAIN_AMOUNT_ALERT_IN=0.05
WIND_GUST_ALERT_MPH=30
HEAT_INDEX_ALERT_F=100