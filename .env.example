# Path to your locations config (copy locations.json.example to locations.json and edit)
LOCATIONS_FILE=locations.json

# Set to 1 to publish to the self-hosted ntfy container (http://ntfy)
# Set to 0 to publish to the public ntfy.sh
NTFY_SELF_HOSTED=0

# SQLite database path — use an absolute path inside a Docker volume mount
DB_PATH=weather.db

# Server — use 0.0.0.0 inside Docker, 127.0.0.1 for local dev
HOST=0.0.0.0
PORT=5000

# Set to 0 in production
FLASK_DEBUG=0

# Scheduler — all optional, defaults shown
DAILY_REPORT_HOUR=7
EVENING_REPORT_HOUR=21
ALERT_INTERVAL_MIN=15

# Database — all optional, defaults shown
DB_RETAIN_DAYS=30

# Error notifications — notify via ntfy after this many consecutive API failures
API_FAILURE_NOTIFY_AFTER=3

# Global alert threshold defaults — all optional, overridden per-location in locations.json
RAIN_PROB_ALERT_PERCENT=50
RAIN_AMOUNT_ALERT_IN=0.05
WIND_GUST_ALERT_MPH=30
HEAT_INDEX_ALERT_F=100
FROST_TEMP_ALERT_F=36
UV_INDEX_ALERT=8